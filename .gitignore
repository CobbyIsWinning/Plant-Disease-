# Root .gitignore for plant-disease-detection

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
venv/
.env

# Jupyter
.ipynb_checkpoints

# Node
node_modules/
/dist

# Dataset and images - exclude raw datasets and images
backend/dataset/
backend/dataset/
backend/dataset/raw/
**/dataset/
*.jpg
*.jpeg
*.png

# Saved models & artifacts
*.h5
*.keras
!backend/saved_models/
!backend/saved_models/*.keras
!backend/saved_models/*.json
*.ckpt
*.pt

# Results / logs / figures
backend/results/
*.log

# Editor files
.vscode/
.idea/
